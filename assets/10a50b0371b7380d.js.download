ch. Ansonsten arbeite ich digital via Videocall – flexibel nach Ihrem Zeitplan."},{q:"Warum nicht einen Baukasten wie Wix oder Jimdo nutzen?",a:"Baukästen sind einfach, aber limitiert. Meine Custom-Entwicklung bietet: Unbegrenzte Anpassungen, bessere Performance (PageSpeed 100 vs. 50-70), professionelles SEO und Unique Design."}];function o(){return(0,t.jsxs)(n.default,{direction:"scale",children:[(0,t.jsx)(l.default,{faqs:i.map(e=>({question:e.q,answer:e.a}))}),(0,t.jsxs)("section",{id:"questions",className:"z-10 sm:p-8 bg-white dark:bg-neutral-950 w-full max-w-7xl border-neutral-200/70 dark:border-neutral-800/40 border rounded-2xl sm:rounded-3xl mx-auto p-4 sm:p-6 shadow-2xl mt-12 sm:mt-24",children:[(0,t.jsx)(n.default,{direction:"up",delay:0,children:(0,t.jsxs)("div",{className:"flex flex-col sm:flex-row gap-3 sm:gap-6 sm:px-0 pr-1 pl-1 sm:items-center",children:[(0,t.jsx)("span",{className:"text-[44px] sm:text-6xl lg:text-7xl xl:text-8xl leading-[0.9] text-zinc-950 dark:text-neutral-100 font-geist tracking-tighter",children:"FAQ."}),(0,t.jsx)("span",{"aria-hidden":"true",role:"separator","aria-orientation":"vertical",className:"hidden sm:block w-px bg-neutral-200 dark:bg-neutral-800 h-10"}),(0,t.jsx)("p",{className:"sm:text-base text-sm text-neutral-500 dark:text-neutral-400 sm:mt-1 font-geist tracking-tight",children:"Klartext statt Fachchinesisch. Die wichtigsten Antworten."})]})}),(0,t.jsx)("div",{className:"h-px bg-neutral-200 dark:bg-neutral-800 mt-4"}),(0,t.jsxs)("div",{className:"flex flex-col gap-6 sm:gap-8 mt-6 sm:mt-8 items-stretch",children:[(0,t.jsx)(n.default,{direction:"left",delay:0,className:"lg:col-span-8",children:(0,t.jsxs)("div",{className:"sm:p-8 text-neutral-900 dark:text-neutral-100 bg-neutral-50/50 dark:bg-neutral-900/50 border-neutral-200 dark:border-neutral-800/40 border rounded-[28px] pt-6 pr-6 pb-6 pl-6 relative h-full flex flex-col gap-0",children:[(0,t.jsx)("span",{className:"text-2xl sm:text-3xl font-geist tracking-tighter mb-6 h-